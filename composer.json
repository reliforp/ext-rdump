{
    "name": "reliforp/ext-rdump",
    "description": "Capture a PHP process's own memory (no ptrace) for offline analysis with reli: leaks, reference cycles, memory bottlenecks.",
    "type": "php-ext",
    "license": "MIT",
    "keywords": ["reli", "memory", "dump", "profiler", "debugging", "extension"],
    "homepage": "https://github.com/reliforp/ext-rdump",
    "authors": [
        {
            "name": "sji",
            "email": "sji@sj-i.dev"
        }
    ],
    "require": {
        "php": ">=7.0"
    },
    "php-ext": {
        "extension-name": "rdump",
        "support-zts": true,
        "support-nts": true,
        "os-families": ["linux"]
    }
}
